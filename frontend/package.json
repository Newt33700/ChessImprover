{
  "name": "chess-improver-frontend",
  "version": "1.0.0",
  "description": "Chess Improver – Frontend Tests",
  "private": true,
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:mutation": "stryker run"
  },
  "devDependencies": {
    "fake-indexeddb": "^4.0.2",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "js/db.js",
      "js/wp_chart.js",
      "js/openings_stats.js",
      "js/endgame_detector.js",
      "js/stats_dashboard.js",
      "js/personal_coach.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80,
        "branches": 80,
        "statements": 80
      }
    }
  }
}
