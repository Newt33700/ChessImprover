{
  "name": "chess-improver-frontend",
  "version": "1.0.0",
  "description": "Chess Improver – Frontend Tests",
  "private": true,
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:mutation": "stryker run",
    "test:e2e": "playwright test",
    "validate:assets": "python3 scripts/validate_assets.py"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "fake-indexeddb": "^4.0.2",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageProvider": "v8",
    "setupFilesAfterEnv": [
      "./tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "js/analysis_feedback.js",
      "js/db.js",
      "js/wp_chart.js",
      "js/openings_stats.js",
      "js/endgame_detector.js",
      "js/stats_dashboard.js",
      "js/personal_coach.js",
      "js/cognitive_dashboard.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80,
        "branches": 70,
        "statements": 80
      }
    }
  }
}
